{
  "name": "animedle-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Animedle monorepo",
  "workspaces": [
    "backend",
    "frontend",
    "data_fetcher"
  ],
  "scripts": {
    "dev": "concurrently \"bun run dev:frontend\" \"bun run dev:backend\"",
    "dev:with-insert": "concurrently \"bun run dev:frontend\" \"bun run dev:backend\"",
    "dev:backend": "cd backend && bun run dev",
    "dev:frontend": "cd frontend && bun run dev",
    "build": "cd frontend && bun run build && cd ../backend && bun run build",
    "insert-data": "bun run start:insert",
    "install:all": "bun install"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "cross-env": "^10.1.0",
    "shadcn": "^4.1.0",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "concurrently": "^9.2.1"
  }
}
